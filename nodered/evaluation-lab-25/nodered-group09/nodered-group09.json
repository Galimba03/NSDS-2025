    {
        "id": "bf25ce992226cfc4",
        "type": "function",
        "z": "8d41263fc5b2da42",
        "name": "Command Parser",
        "func": "delete msg.ts;\ndelete msg.transport;\nmsg.payload.inbound = false;\nmsg.payload.fallback = null;\n\nlet user = msg.payload.userId;\n\nlet commands = msg.payload.content.split(\" \");\n\nlet message = {\n    ...msg,\n    location:{}\n}\n\nif(commands[0] == \"QUERY\"){\n    message.location.city = commands[1];\n    message.location.country = commands[2];\n    return [message, null, null, null];\n}\nelse if(commands[0] == \"TRACK\"){\n    message.payload.content = \"Tracking temperature for \" + commands[1];\n    \n    let array = [];\n\n    if(Array.from(context.keys()).includes(user)){\n        array = Array.from(context.get(user));\n        array.push([commands[1], commands[2]]);\n        context.set(user, array);\n    }\n    else{\n        array.push([commands[1], commands[2]]);\n        context.set(user, array);    \n    }\n    \n    return [null, message, null, null];\n}\nelse if(commands[0] == \"REPORT\"){\n    let array = Array.from(context.get(user));\n    message.payload.content = array;\n    return [null, null, message, null];\n}\nelse{\n    message.payload.content = \"No such command\";\n    return [null, null, null, message];\n}\n",

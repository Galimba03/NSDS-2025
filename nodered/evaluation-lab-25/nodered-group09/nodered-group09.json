        "func": "let locationArray = [];\nfor(let i = 0; i < msg.payload.content.length; i++){\n    let tempMessage = {\n        ...msg,\n        location:{\n            city: msg.payload.content[i][0],\n            country: msg.payload.content[i][1],\n        }\n    }\n    locationArray.push(tempMessage);\n}\n\nreturn [locationArray, null];\n",

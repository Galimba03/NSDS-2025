    {
        "id": "cd458789001e398d",
        "type": "function",
        "z": "cd5ff2d88a712156",
        "name": "op picker",
        "func": "let newPayload = {\n    day: \"\",\n    op: \"\",\n    data: 0,\n    city: \"\",\n};\n\nif(flow.get(\"op\") == 1) {\n    newPayload.op = \"temperature\";\n    newPayload.data = msg.data.main.temp;\n\n    flow.set(\"temperature-count\", flow.get(\"temperature-count\") + 1);\n} else {\n    newPayload.op = \"wind\";\n    msg.payload = msg.data.wind.speed;\n\n    flow.set(\"wind-count\", flow.get(\"wind-count\") + 1);\n}\n\nif(flow.get(\"day\") == 1) {\n    newPayload.day = \"1 day from now\";\n} else {\n    newPayload.day = \"2 days from now\";\n}\n\nif(flow.get(\"city\") == 1) {\n    newPayload.city = \"Milano\";\n} else {\n    newPayload.city = \"Rome\";\n}\n\nmsg.payload = newPayload;\n\nif (context.get(\"last-data\") == newPayload.data) {\n    context.set(\"last-data\", newPayload.data);\n    return [msg, null]; // same as last time\n} else {\n    context.set(\"last-data\", newPayload.data);\n    return [null, msg]; // different from last time\n}",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "// Code added here will be run once\n// whenever the node is started.\ncontext.set(\"last-data\", 0);",
        "finalize": "",

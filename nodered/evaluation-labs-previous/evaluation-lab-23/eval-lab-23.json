    {
        "id": "4a260a3ff9bd90fa",
        "type": "function",
        "z": "cd5ff2d88a712156",
        "name": "command parser",
        "func": "let command = msg.payload.content;\nlet weather_prefix = \"/weather_forecast \";\nlet wind_prefix = \"/wind_forecast \";\n\n// Completely useless because there's the originalMessage in the response message from oper weather\nif(command.includes(weather_prefix) || command.includes(wind_prefix)) {\n    if(command.includes(\"Milan\")) {\n        flow.set(\"city\", 1); // Milan\n    } else if(command.includes(\"Rome\")) {\n        flow.set(\"city\", 2); // Rome\n    } else {\n        return [null, msg];\n    }\n\n    if(command.includes(\"1\")) {\n        flow.set(\"day\", 1); // day 1\n    } else if(command.includes(\"2\")) {\n        flow.set(\"day\", 2); // day 2\n    } else {\n        return [null, msg];\n    }\n\n    if(command.includes(weather_prefix)) {\n        flow.set(\"op\", 1); // temperature\n    } else if(command.includes(wind_prefix)){\n        flow.set(\"op\", 2); // wind\n    } else {\n        return [null, msg];\n    }\n\n    return [msg, null];\n} else {\n    return [null, msg];\n}",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "// Code added here will be run once\n// whenever the node is started.\nflow.set(\"city\", 0); // 1 milan - 2 rome\nflow.set(\"day\", 0); // 1 tomorrow - 2 after tomorrow\nflow.set(\"op\", 0); // 1 temperature - 2 wind\n\nflow.set(\"temperature-count\", 0);\nflow.set(\"wind-count\", 0);",
        "finalize": "",
        "libs": [],

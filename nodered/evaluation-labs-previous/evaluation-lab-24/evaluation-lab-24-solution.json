    {
        "id": "59ee6087bf72c17b",
        "type": "function",
        "z": "f297466f3ce2446a",
        "name": "Sliding the window",
        "func": "if(msg.payload.fields.hasOwnProperty('temperature')){\n    let lastElements = context.get(\"lastElements\");\n    let counter = context.get(\"counter\");\n    lastElements[counter % 10] = msg.payload.fields.temperature;\n    context.set(\"lastElements\", lastElements);\n    context.set(\"counter\", counter+1);\n    msg.payload = lastElements;\n    return msg;\n}else{\n    return null;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "// Code added here will be run once\n// whenever the node is started.\ncontext.set(\"lastElements\", [])\ncontext.set(\"counter\", 0);",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 380,
        "wires": [

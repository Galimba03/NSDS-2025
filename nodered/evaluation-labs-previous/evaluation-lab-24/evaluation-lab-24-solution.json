        "name": "Do the average",
        "func": "let tempArr = msg.payload;\nlet avg = tempArr.length == 0 ? null\n    : tempArr.reduce((acc, c) => acc + c, 0) / tempArr.length;\nmsg.payload = avg;\nreturn msg;",
